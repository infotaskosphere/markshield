# MarkShield Backend — Environment Variables
# Copy to .env and fill values before running in production

SECRET_KEY=change-this-to-a-long-random-string
DEBUG=false
PORT=5000

# Optional: IP India eFiling credentials for portfolio auto-sync
IPINDIA_USERNAME=
IPINDIA_PASSWORD=

# Cache TTL (seconds) — tweak as needed
CACHE_TTL_CAUSE_LIST=300
CACHE_TTL_APPLICATION=600
CACHE_TTL_SEARCH=1800

# Request settings
REQUEST_TIMEOUT=25
REQUEST_RETRIES=3
MIN_DELAY_SECONDS=0.9
