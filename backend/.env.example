SECRET_KEY=markshield-change-this-in-production
PORT=5000

# ── CAPTCHA Solving ───────────────────────────────────────────────────────────
# Option A: Free (default) — uses ddddocr + pytesseract automatically
#   No config needed. ddddocr is ~90% accurate for IP India CAPTCHAs.
#   pytesseract is fallback at ~65% accuracy.
#   If both fail, CAPTCHA image is shown to user to type manually.

# Option B: Paid service (~$1 per 1000 CAPTCHAs, ~99% accuracy)
#   Uncomment ONE of the following:
# CAPTCHA_SERVICE=2captcha
# CAPTCHA_API_KEY=your_2captcha_api_key_here
#
# CAPTCHA_SERVICE=anticaptcha
# CAPTCHA_API_KEY=your_anticaptcha_api_key_here

# ── IP India credentials (optional — for testing) ────────────────────────────
# IPINDIA_USERNAME=manthan15
# IPINDIA_PASSWORD=your_password
