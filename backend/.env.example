# MarkShield Backend — Environment Variables
# Copy to .env and fill values before running in production

SECRET_KEY=change-this-to-a-long-random-string
DEBUG=false
PORT=5000

# ── Google OAuth 2.0 (Calendar + Gmail) ──────────────────────────────
# Step 1: Go to https://console.cloud.google.com/
# Step 2: Create project → Enable "Google Calendar API" + "Gmail API"
# Step 3: Create OAuth 2.0 credentials (Web Application)
# Step 4: Add redirect URI: http://localhost:5000/api/auth/google/callback
# Step 5: Copy Client ID and Secret below

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# For production, change GOOGLE_REDIRECT_URI to your real domain:
# GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/google/callback

# CORS origin (use * for dev, your domain for prod)
CORS_ORIGIN=*

# Optional: IP India eFiling credentials for portfolio auto-sync
IPINDIA_USERNAME=
IPINDIA_PASSWORD=

# Cache TTL (seconds) — tweak as needed
CACHE_TTL_CAUSE_LIST=300
CACHE_TTL_APPLICATION=600
CACHE_TTL_SEARCH=1800

# Request settings
REQUEST_TIMEOUT=25
REQUEST_RETRIES=3
MIN_DELAY_SECONDS=0.9
